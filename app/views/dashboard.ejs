<!DOCTYPE html>
<html class="dark" lang="pl">

<head>
    <%- include('partials/dashboard-head') %>
</head>

<body class="bg-background-dark text-slate-100 font-display antialiased">
    <div class="flex h-screen overflow-hidden">
        <%- include('partials/dashboard-sidebar') %>
            <main class="flex-1 overflow-y-auto">
                <div class="max-w-6xl mx-auto p-10">
                    <header class="mb-12">
                        <h1 class="text-4xl font-black tracking-tight text-white">Witaj, <%= user.restaurantName %>!
                        </h1>
                        <p class="text-slate-400 mt-2 text-lg">Zarządzaj swoim cyfrowym menu.</p>
                    </header>
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
                        <div class="lg:col-span-2 space-y-10">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <div class="bg-sidebar-dark p-8 rounded-2xl border border-slate-800 amber-glow">
                                    <div class="flex items-center justify-between mb-4">
                                        <span
                                            class="material-symbols-outlined text-primary bg-primary/10 p-3 rounded-xl">qr_code_2</span>
                                    </div>
                                    <p class="text-slate-500 text-sm font-bold uppercase tracking-wider">Aktywne kody QR
                                    </p>
                                    <p class="text-4xl font-black mt-2 text-white">
                                        <%= stats.qrCount || 0 %>
                                    </p>
                                </div>
                                <div class="bg-sidebar-dark p-8 rounded-2xl border border-slate-800 amber-glow">
                                    <div class="flex items-center justify-between mb-4">
                                        <span
                                            class="material-symbols-outlined text-primary bg-primary/10 p-3 rounded-xl">restaurant</span>
                                    </div>
                                    <p class="text-slate-500 text-sm font-bold uppercase tracking-wider">Pozycje w menu
                                    </p>
                                    <p class="text-4xl font-black mt-2 text-white">
                                        <%= stats.itemsCount || 0 %>
                                    </p>
                                </div>
                            </div>
                            <div class="grid grid-cols-1 gap-6">
                                <a href="/menu"
                                    class="block group w-full flex items-center justify-between p-8 bg-sidebar-dark rounded-2xl border-2 border-primary text-left amber-glow transition-all hover:bg-primary/5">
                                    <div class="flex items-center gap-6">
                                        <div
                                            class="bg-primary text-sidebar-dark p-4 rounded-xl group-hover:scale-110 transition-transform">
                                            <span class="material-symbols-outlined text-3xl font-bold">edit_note</span>
                                        </div>
                                        <div>
                                            <h3 class="text-2xl font-black text-white">Stwórz / Edytuj Menu</h3>
                                            <p class="text-slate-400 mt-1">Dodaj dania, zdjęcia i zaktualizuj ceny w
                                                czasie rzeczywistym.</p>
                                        </div>
                                    </div>
                                    <span class="material-symbols-outlined text-primary">arrow_forward_ios</span>
                                </a>
                                <a href="/qr"
                                    class="block group w-full flex items-center justify-between p-8 bg-sidebar-dark rounded-2xl border-2 border-slate-800 text-left transition-all hover:border-primary/50">
                                    <div class="flex items-center gap-6">
                                        <div
                                            class="bg-slate-800 text-primary p-4 rounded-xl group-hover:bg-primary/20 transition-colors">
                                            <span
                                                class="material-symbols-outlined text-3xl font-bold">qr_code_scanner</span>
                                        </div>
                                        <div>
                                            <h3 class="text-2xl font-black text-white">Wygeneruj kody QR</h3>
                                            <p class="text-slate-400 mt-1">Pobierz gotowe kody QR do wydruku na stoliki
                                                restauracji.</p>
                                        </div>
                                    </div>
                                    <span
                                        class="material-symbols-outlined text-slate-600 group-hover:text-primary transition-colors">arrow_forward_ios</span>
                                </a>
                            </div>
                        </div>
                        <div class="flex flex-col">
                            <div
                                class="bg-sidebar-dark p-8 rounded-3xl border border-slate-800 flex flex-col items-center">
                                <h3 class="text-sm font-bold text-slate-500 uppercase tracking-widest mb-8">Podgląd na
                                    żywo</h3>
                                <div
                                    class="relative w-[260px] h-[520px] bg-black rounded-[2.5rem] border-[6px] border-slate-800 shadow-2xl overflow-hidden ring-4 ring-slate-900/20">
                                    <div
                                        class="absolute top-0 left-1/2 -translate-x-1/2 w-28 h-5 bg-slate-800 rounded-b-xl z-20">
                                    </div>
                                    <div
                                        class="absolute inset-0 bg-background-dark overflow-y-auto flex flex-col rounded-[2.1rem] [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
                                        <!-- Hero / Header -->
                                        <header
                                            class="bg-sidebar-dark border-b border-slate-800 sticky top-0 z-50 shadow-lg shadow-black/50">
                                            <!-- pt-6 dodane by odsunąć treść od 'notcha' u góry, ale zachowując tło -->
                                            <div
                                                class="px-2 pb-3 pt-6 flex items-center justify-center relative overflow-hidden">
                                                <div
                                                    class="absolute inset-0 bg-gradient-to-r from-primary/10 via-transparent to-primary/10 opacity-50">
                                                </div>
                                                <h1
                                                    class="text-sm font-black text-white relative z-10 tracking-tight text-center line-clamp-1 w-full px-2">
                                                    <%= user.restaurantName %>
                                                </h1>
                                            </div>
                                        </header>

                                        <main class="w-full flex-1 px-3 py-4">
                                            <% if (menu && menu.categories && menu.categories.length> 0) { %>
                                                <div class="space-y-5">
                                                    <% let renderedCategories=0; %>
                                                        <% menu.categories.forEach(category=> { %>
                                                            <% const availableItems=category.items.filter(item=>
                                                                item.isAvailable); %>
                                                                <% if (availableItems.length> 0 && renderedCategories <
                                                                        2) { %>
                                                                        <% renderedCategories++; %>
                                                                            <section>
                                                                                <h2
                                                                                    class="text-[12px] font-black text-primary mb-3 flex items-center gap-2 border-b border-slate-800 pb-1.5">
                                                                                    <%= category.name %>
                                                                                </h2>
                                                                                <div class="grid grid-cols-1 gap-3">
                                                                                    <% availableItems.slice(0,
                                                                                        2).forEach(item=> { %>
                                                                                        <div
                                                                                            class="bg-sidebar-dark rounded-xl p-2.5 border border-slate-800 shadow-sm flex gap-3 mix-blend-lighten">
                                                                                            <% if (item.image) { %>
                                                                                                <div
                                                                                                    class="size-12 shrink-0 rounded-lg overflow-hidden bg-background-dark border border-slate-700">
                                                                                                    <img src="<%= item.image %>"
                                                                                                        class="w-full h-full object-cover">
                                                                                                </div>
                                                                                                <% } else { %>
                                                                                                    <div
                                                                                                        class="size-12 shrink-0 rounded-lg bg-background-dark flex items-center justify-center border border-slate-700">
                                                                                                        <span
                                                                                                            class="material-symbols-outlined text-slate-600 text-[14px]">fastfood</span>
                                                                                                    </div>
                                                                                                    <% } %>

                                                                                                        <div
                                                                                                            class="flex-1 flex flex-col justify-between py-0.5">
                                                                                                            <div>
                                                                                                                <h3
                                                                                                                    class="font-bold text-slate-100 text-[10px] leading-tight mb-0.5">
                                                                                                                    <%= item.name
                                                                                                                        %>
                                                                                                                </h3>
                                                                                                                <% if
                                                                                                                    (item.description)
                                                                                                                    { %>
                                                                                                                    <p
                                                                                                                        class="text-[8px] text-slate-400 line-clamp-2 leading-snug">
                                                                                                                        <%= item.description
                                                                                                                            %>
                                                                                                                    </p>
                                                                                                                    <% }
                                                                                                                        %>
                                                                                                            </div>
                                                                                                            <div
                                                                                                                class="mt-1 text-primary font-black text-[11px]">
                                                                                                                <%= item.price.toFixed(2).replace('.', ','
                                                                                                                    ) %>
                                                                                                                    <span
                                                                                                                        class="text-[8px]">zł</span>
                                                                                                            </div>
                                                                                                        </div>
                                                                                        </div>
                                                                                        <% }) %>
                                                                                </div>
                                                                            </section>
                                                                            <% } %>
                                                                                <% }) %>
                                                </div>
                                                <div
                                                    class="text-center py-4 mt-6 border-t border-slate-800/50 bg-sidebar-dark -mx-3 -mb-4 pb-6">
                                                    <p class="text-[8px] text-slate-500 font-medium tracking-wide">
                                                        Obsługiwane przez <span
                                                            class="text-primary font-black">QResto</span></p>
                                                </div>
                                                <% } else { %>
                                                    <div class="text-center py-10 flex flex-col items-center">
                                                        <span
                                                            class="material-symbols-outlined text-slate-600 text-2xl mb-2">restaurant</span>
                                                        <p class="text-[10px] text-slate-400">Menu w budowie</p>
                                                    </div>
                                                    <% } %>
                                        </main>
                                    </div>
                                </div>
                                <p
                                    class="mt-8 text-[11px] text-slate-500 text-center max-w-[180px] leading-relaxed italic">
                                    Tak Twoje menu prezentuje się klientom na urządzeniach mobilnych.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
    </div>
</body>

</html>