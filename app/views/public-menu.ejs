<!DOCTYPE html>
<html class="dark" lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= restaurantName %> | Menu QResto
    </title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#f2a60d",
                        "background-light": "#f8f7f5",
                        "background-dark": "#1a1a1a",
                        "sidebar-dark": "#111111",
                        "border-dark": "#333333",
                        "border-subtle": "#333333",
                        "accent-dark": "#2a2a2a"
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style type="text/tailwindcss">
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>

<body class="bg-background-dark text-slate-100 antialiased min-h-screen flex flex-col">
    <!-- Hero / Header -->
    <header class="bg-sidebar-dark border-b border-slate-800 sticky top-0 z-50 shadow-lg shadow-black/50">
        <div class="max-w-3xl mx-auto px-4 py-4 flex items-center justify-center relative overflow-hidden">
            <!-- Subtle accent background -->
            <div class="absolute inset-0 bg-gradient-to-r from-primary/10 via-transparent to-primary/10 opacity-50">
            </div>
            <h1 class="text-xl md:text-2xl font-black text-white relative z-10 tracking-tight text-center">
                <%= restaurantName %>
            </h1>
        </div>
    </header>

    <main class="max-w-3xl mx-auto px-4 py-6 w-full flex-1">
        <% if (!menu || !menu.categories || menu.categories.length===0) { %>
            <div class="text-center py-10 flex flex-col items-center">
                <span class="material-symbols-outlined text-slate-600 text-5xl mb-4">restaurant</span>
                <p class="text-slate-400 text-lg">Menu jest w trakcie przygotowywania.</p>
            </div>
            <% } else { %>
                <% let hasAvailableItems=false; %>

                    <div class="space-y-8">
                        <% menu.categories.forEach(category=> { %>
                            <% const availableItems=category.items.filter(item=> item.isAvailable); %>
                                <% if (availableItems.length> 0) { %>
                                    <% hasAvailableItems=true; %>
                                        <section>
                                            <h2
                                                class="text-2xl font-black text-primary mb-6 flex items-center gap-2 border-b border-slate-800 pb-3">
                                                <%= category.name %>
                                            </h2>
                                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                                <% availableItems.forEach(item=> { %>
                                                    <div
                                                        class="bg-sidebar-dark rounded-2xl p-4 border border-slate-800 shadow-sm flex gap-4 transition-transform hover:border-primary/30">
                                                        <!-- Image -->
                                                        <% if (item.image) { %>
                                                            <div
                                                                class="w-24 h-24 sm:w-28 sm:h-28 shrink-0 rounded-xl overflow-hidden bg-background-dark border border-slate-700">
                                                                <img src="<%= item.image %>" alt="<%= item.name %>"
                                                                    class="w-full h-full object-cover">
                                                            </div>
                                                            <% } else { %>
                                                                <div
                                                                    class="w-24 h-24 sm:w-28 sm:h-28 shrink-0 rounded-xl bg-background-dark flex items-center justify-center border border-slate-700">
                                                                    <span
                                                                        class="material-symbols-outlined text-slate-600">fastfood</span>
                                                                </div>
                                                                <% } %>

                                                                    <!-- Content -->
                                                                    <div
                                                                        class="flex-1 flex flex-col justify-between py-1">
                                                                        <div>
                                                                            <h3
                                                                                class="font-bold text-slate-100 text-lg leading-tight mb-1">
                                                                                <%= item.name %>
                                                                            </h3>
                                                                            <% if (item.description) { %>
                                                                                <p
                                                                                    class="text-sm text-slate-400 line-clamp-3 leading-snug">
                                                                                    <%= item.description %>
                                                                                </p>
                                                                                <% } %>
                                                                        </div>
                                                                        <div
                                                                            class="mt-2 text-primary font-black text-xl">
                                                                            <%= item.price.toFixed(2).replace('.', ',' )
                                                                                %> <span class="text-sm">zł</span>
                                                                        </div>
                                                                    </div>
                                                    </div>
                                                    <% }) %>
                                            </div>
                                        </section>
                                        <% } %>
                                            <% }) %>

                                                <% if (!hasAvailableItems) { %>
                                                    <div class="text-center py-20 flex flex-col items-center">
                                                        <span
                                                            class="material-symbols-outlined text-slate-600 text-5xl mb-4">restaurant_menu</span>
                                                        <p class="text-slate-400 text-lg">Brak dostępnych dań w ofercie.
                                                        </p>
                                                    </div>
                                                    <% } %>
                    </div>
                    <% } %>
    </main>

    <footer class="text-center py-6 mt-auto border-t border-slate-800/50 bg-sidebar-dark">
        <p class="text-xs text-slate-500 font-medium tracking-wide">Obsługiwane przez <span
                class="text-primary font-black">QResto</span></p>
    </footer>
</body>

</html>