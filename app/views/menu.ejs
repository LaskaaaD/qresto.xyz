<!DOCTYPE html>
<html class="dark" lang="pl">

<head>
    <%- include('partials/dashboard-head') %>
</head>

<body class="bg-background-dark text-slate-100 font-display antialiased">
    <div class="flex h-screen overflow-hidden">
        <%- include('partials/dashboard-sidebar') %>
            <main class="flex-1 overflow-y-auto relative">
                <!-- Top Header -->
                <header
                    class="p-8 border-b border-border-subtle bg-background-dark/80 backdrop-blur-md sticky top-0 z-10">
                    <div class="max-w-5xl mx-auto flex flex-col md:flex-row md:items-end justify-between gap-6">
                        <div class="space-y-1">
                            <h2 class="text-3xl font-black text-slate-100 tracking-tight">Zarządzaj Menu</h2>
                            <p class="text-slate-400">Kreator cyfrowego menu Twojej restauracji.</p>
                        </div>
                        <div class="flex gap-3">
                            <button onclick="document.getElementById('addCategoryModal').showModal()"
                                class="flex items-center gap-2 bg-transparent border border-primary text-primary hover:bg-primary/5 px-5 py-2.5 rounded-lg font-bold text-sm transition-all shadow-[0_0_15px_rgba(234,179,8,0.1)]">
                                <span class="material-symbols-outlined text-[20px]">add_circle</span>
                                Dodaj kategorię
                            </button>
                            <button onclick="document.getElementById('addItemModal').showModal()"
                                class="flex items-center gap-2 bg-primary text-sidebar-dark hover:brightness-110 px-5 py-2.5 rounded-lg font-bold text-sm transition-all shadow-lg shadow-primary/20">
                                <span class="material-symbols-outlined text-[20px]">add</span>
                                Dodaj nowe danie
                            </button>
                        </div>
                    </div>
                </header>

                <!-- Error/Success Messages -->
                <% if (typeof error !=='undefined' && error) { %>
                    <div class="max-w-5xl mx-auto mt-6 px-8">
                        <div
                            class="bg-red-500/10 border border-red-500/30 text-red-500 px-4 py-3 rounded-lg text-sm font-bold flex items-center gap-2">
                            <span class="material-symbols-outlined">error</span>
                            <%= error %>
                        </div>
                    </div>
                    <% } %>

                        <!-- Menu Content -->
                        <div class="max-w-5xl mx-auto p-8 pb-32">
                            <% if (menu && menu.categories && menu.categories.length> 0) { %>
                                <% menu.categories.forEach(category=> { %>
                                    <section class="mb-12">
                                        <div class="flex items-center justify-between mb-6">
                                            <div class="flex items-center gap-3">
                                                <span
                                                    class="material-symbols-outlined text-primary">restaurant_menu</span>
                                                <h3 class="text-xl font-bold text-slate-100">
                                                    <%= category.name %>
                                                </h3>
                                                <span
                                                    class="text-xs bg-slate-800 text-slate-400 px-2 py-0.5 rounded-full font-medium">
                                                    <%= category.items.length %> pozycje
                                                </span>
                                            </div>
                                            <form action="/menu/category/<%= category._id %>/delete" method="POST"
                                                class="inline"
                                                onsubmit="return confirm('Na pewno usunąć tę kategorię i wszystkie jej dania?');">
                                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                <button
                                                    class="p-2 text-slate-400 hover:text-red-400 hover:bg-red-400/10 rounded-lg transition-all"
                                                    title="Usuń kategorię">
                                                    <span class="material-symbols-outlined text-lg">delete</span>
                                                </button>
                                            </form>
                                        </div>
                                        <div
                                            class="bg-sidebar-dark rounded-xl border border-border-subtle overflow-hidden">
                                            <% if (category.items && category.items.length> 0) { %>
                                                <% category.items.forEach((item, index)=> { %>
                                                    <div
                                                        class="flex items-center p-4 gap-4 <%= index !== category.items.length - 1 ? 'border-b border-border-subtle' : '' %> hover:bg-white/[0.02] transition-colors group <%= !item.isAvailable ? 'opacity-50 grayscale' : '' %>">
                                                        <div
                                                            class="size-16 rounded-lg overflow-hidden bg-slate-800 flex-shrink-0 relative">
                                                            <% if (item.image) { %>
                                                                <img src="<%= item.image %>" alt="<%= item.name %>"
                                                                    class="w-full h-full object-cover">
                                                                <% } else { %>
                                                                    <div
                                                                        class="w-full h-full bg-gradient-to-br from-slate-700 to-slate-800 flex items-center justify-center">
                                                                        <span
                                                                            class="material-symbols-outlined text-slate-600">image</span>
                                                                    </div>
                                                                    <% } %>
                                                        </div>
                                                        <div class="flex-1">
                                                            <h4 class="font-bold text-slate-100">
                                                                <%= item.name %>
                                                            </h4>
                                                            <p class="text-sm text-slate-400 line-clamp-1">
                                                                <%= item.description %>
                                                            </p>
                                                            <% if (!item.isAvailable) { %>
                                                                <span
                                                                    class="inline-block mt-1 text-[10px] uppercase font-bold text-red-400 bg-red-400/10 px-2 pl-0 rounded">Niedostępne</span>
                                                                <% } %>
                                                        </div>
                                                        <div class="text-primary font-bold px-4">
                                                            <%= item.price %> PLN
                                                        </div>
                                                        <div class="flex gap-2">
                                                            <div
                                                                class="opacity-0 group-hover:opacity-100 transition-opacity flex gap-2">
                                                                <button
                                                                    onclick="openEditModal('<%= item._id %>', '<%= item.name %>', '<%= item.description %>', '<%= item.price %>', <%= item.isAvailable %>, '<%= category._id %>')"
                                                                    class="p-2 text-slate-400 hover:text-primary hover:bg-primary/10 rounded-lg transition-all">
                                                                    <span
                                                                        class="material-symbols-outlined text-lg">edit</span>
                                                                </button>
                                                                <form action="/menu/item/<%= item._id %>/delete"
                                                                    method="POST" class="inline"
                                                                    onsubmit="return confirm('Usunąć to danie?');">
                                                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                                                    <button type="submit"
                                                                        class="p-2 text-slate-400 hover:text-red-400 hover:bg-red-400/10 rounded-lg transition-all">
                                                                        <span
                                                                            class="material-symbols-outlined text-lg">delete</span>
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <% }) %>
                                                        <% } else { %>
                                                            <div class="p-8 text-center text-slate-500 text-sm">
                                                                Brak dań w tej kategorii. Dodaj nowe danie, by klienci
                                                                mogli je zobaczyć.
                                                            </div>
                                                            <% } %>
                                        </div>
                                    </section>
                                    <% }) %>
                                        <% } else { %>
                                            <div class="text-center py-20 flex flex-col items-center">
                                                <div
                                                    class="size-20 bg-primary/10 rounded-full flex items-center justify-center mb-6">
                                                    <span
                                                        class="material-symbols-outlined text-primary text-4xl">restaurant_menu</span>
                                                </div>
                                                <h3 class="text-2xl font-bold text-slate-100 mb-2">Twoje menu jest puste
                                                </h3>
                                                <p class="text-slate-400 mb-8 max-w-md mx-auto">Rozpocznij tworzenie
                                                    swojego cyfrowego menu od dodania pierwszej kategorii, a następnie
                                                    wypełnij ją pysznymi daniami.</p>
                                                <button
                                                    onclick="document.getElementById('addCategoryModal').showModal()"
                                                    class="bg-primary text-sidebar-dark font-bold px-6 py-3 rounded-lg hover:brightness-110 transition-all inline-flex items-center gap-2">
                                                    <span class="material-symbols-outlined">add</span>
                                                    Stwórz pierwszą kategorię
                                                </button>
                                            </div>
                                            <% } %>
                        </div>
            </main>
    </div>

    <!-- Add Category Modal -->
    <dialog id="addCategoryModal"
        class="bg-sidebar-dark border border-border-subtle rounded-xl shadow-2xl backdrop:bg-black/60 backdrop:backdrop-blur-sm p-0 text-slate-100 w-full max-w-md open:animate-in open:fade-in open:zoom-in-95">
        <form action="/menu/category" method="POST" class="flex flex-col">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="p-6 border-b border-border-subtle flex items-center justify-between">
                <h3 class="text-xl font-bold">Dodaj nową kategorię</h3>
                <button type="button" onclick="document.getElementById('addCategoryModal').close()"
                    class="text-slate-400 hover:text-white transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <div class="p-6">
                <label class="block text-sm font-medium text-slate-400 mb-2">Nazwa kategorii (np. Przystawki)</label>
                <input type="text" name="name" required
                    class="w-full bg-background-dark border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
            </div>
            <div class="p-6 border-t border-border-subtle flex justify-end gap-3 bg-black/20">
                <button type="button" onclick="document.getElementById('addCategoryModal').close()"
                    class="px-5 py-2.5 rounded-lg border border-slate-700 text-slate-300 hover:bg-slate-800 transition-colors font-bold text-sm">Anuluj</button>
                <button type="submit"
                    class="px-5 py-2.5 rounded-lg bg-primary text-background-dark hover:brightness-110 transition-all font-bold text-sm">Dodaj
                    kategorię</button>
            </div>
        </form>
    </dialog>

    <!-- Add Item Modal -->
    <dialog id="addItemModal"
        class="bg-sidebar-dark border border-border-subtle rounded-xl shadow-2xl backdrop:bg-black/60 backdrop:backdrop-blur-sm p-0 text-slate-100 w-full max-w-lg open:animate-in open:fade-in open:zoom-in-95">
        <% if (menu && menu.categories && menu.categories.length> 0) { %>
            <form action="/menu/category/<%= menu.categories[0]._id %>/item?_csrf=<%= encodeURIComponent(csrfToken) %>" method="POST" enctype="multipart/form-data"
                class="flex flex-col" id="addItemForm">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="p-6 border-b border-border-subtle flex items-center justify-between">
                    <h3 class="text-xl font-bold">Dodaj nowe danie</h3>
                    <button type="button" onclick="document.getElementById('addItemModal').close()"
                        class="text-slate-400 hover:text-white transition-colors">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                <div class="p-6 space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Wybierz kategorię</label>
                        <select name="categoryId"
                            onchange="document.getElementById('addItemForm').action = '/menu/category/' + this.value + '/item?_csrf=<%= encodeURIComponent(csrfToken) %>';"
                            class="w-full bg-background-dark border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                            <% menu.categories.forEach(category=> { %>
                                <option value="<%= category._id %>">
                                    <%= category.name %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Nazwa dania</label>
                        <input type="text" name="name" required
                            class="w-full bg-background-dark border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Opis i składniki</label>
                        <textarea name="description" rows="2"
                            class="w-full bg-background-dark border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all"></textarea>
                    </div>
                    <div class="flex gap-4">
                        <div class="w-1/2">
                            <label class="block text-sm font-medium text-slate-400 mb-2">Cena (PLN)</label>
                            <input type="number" step="0.01" name="price" required
                                class="w-full bg-background-dark border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                        </div>
                        <div class="w-1/2 flex items-center pt-8">
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" name="isAvailable" checked
                                    class="w-5 h-5 accent-primary rounded cursor-pointer bg-background-dark border-slate-700">
                                <span class="text-sm font-medium text-slate-200">Dostępne w menu</span>
                            </label>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Zdjęcie (opcjonalnie)</label>
                        <input type="file" name="image" accept="image/*"
                            class="w-full text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 transition-all cursor-pointer">
                    </div>
                </div>
                <div class="p-6 border-t border-border-subtle flex justify-end gap-3 bg-black/20">
                    <button type="button" onclick="document.getElementById('addItemModal').close()"
                        class="px-5 py-2.5 rounded-lg border border-slate-700 text-slate-300 hover:bg-slate-800 transition-colors font-bold text-sm">Anuluj</button>
                    <button type="submit"
                        class="px-5 py-2.5 rounded-lg bg-primary text-background-dark hover:brightness-110 transition-all font-bold text-sm">Dodaj
                        danie</button>
                </div>
            </form>
            <% } else { %>
                <div class="p-8 text-center bg-sidebar-dark flex flex-col items-center">
                    <div class="size-16 bg-primary/10 rounded-full flex items-center justify-center mb-4">
                        <span class="material-symbols-outlined text-primary text-2xl">error</span>
                    </div>
                    <h3 class="text-xl font-bold mb-2">Brak kategorii</h3>
                    <p class="text-slate-400 mb-6 max-w-sm">Musisz najpierw stworzyć kategorię (np. "Przystawki"), aby
                        móc dołączać do niej pozycje menu.</p>
                    <div class="flex gap-3 justify-center">
                        <button type="button" onclick="document.getElementById('addItemModal').close()"
                            class="px-5 py-2.5 rounded-lg border border-slate-700 text-slate-300 hover:bg-slate-800 transition-colors font-bold text-sm">Zamknij</button>
                        <button type="button"
                            onclick="document.getElementById('addItemModal').close(); document.getElementById('addCategoryModal').showModal();"
                            class="px-5 py-2.5 rounded-lg bg-primary text-background-dark hover:brightness-110 transition-all font-bold text-sm">Stwórz
                            nową kategorię</button>
                    </div>
                </div>
                <% } %>
    </dialog>

    <!-- Edit Item Modal -->
    <dialog id="editItemModal"
        class="bg-sidebar-dark border border-border-subtle rounded-xl shadow-2xl backdrop:bg-black/60 backdrop:backdrop-blur-sm p-0 text-slate-100 w-full max-w-lg open:animate-in open:fade-in open:zoom-in-95">
        <% if (menu && menu.categories && menu.categories.length> 0) { %>
            <form id="editItemForm" method="POST" enctype="multipart/form-data" class="flex flex-col">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <div class="p-6 border-b border-border-subtle flex items-center justify-between">
                    <h3 class="text-xl font-bold">Edytuj danie</h3>
                    <button type="button" onclick="document.getElementById('editItemModal').close()"
                        class="text-slate-400 hover:text-white transition-colors">
                        <span class="material-symbols-outlined">close</span>
                    </button>
                </div>
                <div class="p-6 space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Kategoria</label>
                        <select name="categoryId" id="editItemCategory"
                            class="w-full bg-background-dark border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                            <% menu.categories.forEach(category=> { %>
                                <option value="<%= category._id %>">
                                    <%= category.name %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Nazwa dania</label>
                        <input type="text" id="editItemName" name="name" required
                            class="w-full bg-background-dark border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Opis i składniki</label>
                        <textarea id="editItemDesc" name="description" rows="2"
                            class="w-full bg-background-dark border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all"></textarea>
                    </div>
                    <div class="flex gap-4">
                        <div class="w-1/2">
                            <label class="block text-sm font-medium text-slate-400 mb-2">Cena (PLN)</label>
                            <input type="number" id="editItemPrice" step="0.01" name="price" required
                                class="w-full bg-background-dark border border-slate-700 rounded-lg px-4 py-3 text-white placeholder-slate-500 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all">
                        </div>
                        <div class="w-1/2 flex items-center pt-8">
                            <label class="flex items-center gap-3 cursor-pointer">
                                <input type="checkbox" id="editItemAvailable" name="isAvailable"
                                    class="w-5 h-5 accent-primary rounded cursor-pointer bg-background-dark border-slate-700">
                                <span class="text-sm font-medium text-slate-200">Dostępne w menu</span>
                            </label>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-400 mb-2">Nowe zdjęcie (opcjonalnie, nadpisze
                            stare)</label>
                        <input type="file" name="image" accept="image/*"
                            class="w-full text-slate-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 transition-all cursor-pointer">
                    </div>
                </div>
                <div class="p-6 border-t border-border-subtle flex justify-end gap-3 bg-black/20">
                    <button type="button" onclick="document.getElementById('editItemModal').close()"
                        class="px-5 py-2.5 rounded-lg border border-slate-700 text-slate-300 hover:bg-slate-800 transition-colors font-bold text-sm">Anuluj</button>
                    <button type="submit"
                        class="px-5 py-2.5 rounded-lg bg-primary text-background-dark hover:brightness-110 transition-all font-bold text-sm">Zapisz
                        zmiany</button>
                </div>
            </form>
            <% } %>
    </dialog>

    <!-- Client Script for Modals -->
    <script>
        function openEditModal(id, name, desc, price, available, categoryId) {
            document.getElementById('editItemForm').action = '/menu/item/' + id + '/edit?_csrf=<%= encodeURIComponent(csrfToken) %>';
            document.getElementById('editItemName').value = name;
            document.getElementById('editItemDesc').value = desc;
            document.getElementById('editItemPrice').value = price;
            document.getElementById('editItemAvailable').checked = available;
            document.getElementById('editItemCategory').value = categoryId;
            document.getElementById('editItemModal').showModal();
        }
    </script>
</body>

</html>