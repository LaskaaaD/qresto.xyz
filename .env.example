# Routing i SSL (Traefik)
ROOT_DOMAIN=example.com
APP_DOMAIN=example.com
APP_WWW_DOMAIN=www.example.com
ZABBIX_DOMAIN=zabbix.example.com
SSL_EMAIL=admin@example.com
CF_DNS_API_TOKEN=CHANGE_ME_CLOUDFLARE_DNS_API_TOKEN

# Obraz aplikacji (artefakt z GHCR)
APP_IMAGE=ghcr.io/owner/repo:main

# Skalowanie aplikacji (demo)
APP_REPLICAS=1

# MongoDB (kontener aplikacji)
MONGO_USER=qresto_admin
MONGO_PASS=CHANGE_ME_STRONG_MONGO_PASSWORD
MONGO_DB=qresto
MONGODB_URI=mongodb://qresto_admin:CHANGE_ME_STRONG_MONGO_PASSWORD@mongodb:27017/qresto?authSource=admin

# Aplikacja
SESSION_SECRET=CHANGE_ME_STRONG_SESSION_SECRET

# Zabbix (PostgreSQL)
ZABBIX_DB_USER=zabbix
ZABBIX_DB_PASS=CHANGE_ME_STRONG_ZABBIX_PASSWORD

# Zabbix API / alerty (dla skryptu bootstrap)
ZABBIX_API_USER=Admin
ZABBIX_API_PASSWORD=zabbix
ZABBIX_HOSTNAME=qresto-vps-agent

# Telegram (powiadomienia CI/CD i alerty certyfikatów)
# Uzyj surowego tokena bota, np. 123456789:AA... (bez prefiksu "bot", bez URL)
TELEGRAM_BOT_TOKEN=CHANGE_ME_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=CHANGE_ME_TELEGRAM_CHAT_ID
TELEGRAM_CERT_ALERT_DAYS=20
