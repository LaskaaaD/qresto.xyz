# QResto environment template
# Copy to .env on the VPS and replace every placeholder before deployment.

# Routing and TLS
ROOT_DOMAIN=example.com
ROOT_DOMAIN_REGEX=example\\.com
APP_DOMAIN=example.com
APP_WWW_DOMAIN=www.example.com
ZABBIX_DOMAIN=zabbix.example.com
SSL_EMAIL=admin@example.com
CF_DNS_API_TOKEN=replace_with_cloudflare_dns_api_token

# Application image
APP_IMAGE=ghcr.io/owner/qresto:main
APP_REPLICAS=1

# MongoDB
MONGO_USER=qresto_admin
MONGO_PASS=replace_with_strong_mongodb_password
MONGO_DB=qresto
MONGODB_URI=mongodb://qresto_admin:replace_with_strong_mongodb_password@mongodb:27017/qresto?authSource=admin

# Express
NODE_ENV=production
SESSION_SECRET=replace_with_random_min_32_chars

# Zabbix PostgreSQL
ZABBIX_DB_USER=zabbix
ZABBIX_DB_PASS=replace_with_strong_zabbix_db_password

# Zabbix API bootstrap
ZABBIX_API_USER=Admin
ZABBIX_API_PASSWORD=replace_with_strong_zabbix_api_password
ZABBIX_HOSTNAME=qresto-vps-agent

# Optional notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CERT_ALERT_DAYS=20
